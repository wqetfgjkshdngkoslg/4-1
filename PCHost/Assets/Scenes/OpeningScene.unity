  imageGroups:
  - {fileID: 614929687}
  - {fileID: 2028315128}
  - {fileID: 645039304}
  - {fileID: 1557975609}
  - {fileID: 1513149922}
  - {fileID: 336156698}
  storyLines:
  - "\uB530\uB974\uB974\uB989!!!\n\u201C\uAC70\uAE30 \uACBD\uCC30\uC11C\uC8E0? \uAC15\uB3C4\uAC00
    \uB098\uD0C0\uB0AC\uC5B4\uC694!\u201D"
  - "\u201C\uBC29\uAE08 \uD3B8\uC758\uC810\uC5D0\uC11C \uAC15\uB3C4 \uC0AC\uAC74\uC774
    \uBC1C\uC0DD\uD588\uB2E4!\u201D\n\u201C\uBAA8\uB450 \uC989\uC2DC \uC900\uBE44\uD558\uACE0
    \uCD9C\uB3D9 \uB300\uAE30!\u201D"
  - "\u201C\uC6A9\uC758\uC790\uB294 \uB3C4\uC8FC \uC911, \uBE60\uB974\uAC8C \uAC80\uAC70\uD574\uC57C
    \uD55C\uB2E4!\u201D\n\u201C\uC791\uC804\uC744 \uC138\uC6B0\uACE0 \uBC14\uB85C
    \uC6C0\uC9C1\uC778\uB2E4!\u201D"
  - "\u201C\uCD9C\uB3D9\uD55C\uB2E4! \uC9C0\uAE08 \uB2F9\uC7A5 \uD3B8\uC758\uC810\uC73C\uB85C
    \uAC04\uB2E4!\u201D\n\uACBD\uCC30\uB4E4\uC740 \uC11C\uB458\uB7EC \uD604\uC7A5\uC73C\uB85C
    \uD5A5\uD588\uB2E4!"
  - "\u201C\uBC94\uC778\uC740 \uC544\uC9C1 \uADFC\uCC98\uC5D0 \uC788\uC744 \uAC00\uB2A5\uC131\uC774
    \uB192\uB2E4\u2026\u201D\n\u201C\uC11C\uB458\uB7EC! \uC2DC\uAC04\uC744 \uB193\uCE58\uBA74
    \uC704\uD5D8\uD574!\u201D"
  - "\uC5EC\uB7EC\uBD84\uB4E4\uC758 \uD798\uC774 \uD544\uC694\uD574\uC694! OO\uD3B8\uC758\uC810\uC758
    \uAC15\uB3C4\uB97C \uC5EC\uB7EC\uBD84\uB4E4\uC758 \uC190\uC73C\uB85C \uC7A1\uC544\uC8FC\uC138\uC694!!!!"
  storyText: {fileID: 1125695052}
  fadeDuration: 1
  charInterval: 0.03
  waitAfterTyping: 2
